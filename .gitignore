# ── Binaries ──────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
/bin/
/dist/

# ── Go ────────────────────────────────────────────────────
*.test
*.out
go.work
go.work.sum
vendor/

# ── Web (React + Vite) ────────────────────────────────────
node_modules/
web/dist/
web/.vite/
*.local

# ── Secrets & certificates — NEVER commit ─────────────────
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
deploy/certs/*
!deploy/certs/.gitkeep
!deploy/certs/*.sh
!deploy/certs/*.ps1
!deploy/certs/README.md
.env
.env.*
!.env.example

# ── Data volume (Postgres / NATS) ─────────────────────────
/data/
*.db
*.sqlite

# ── Buffer store-and-forward agent ────────────────────────
/agent-buffer/

# ── Editor / OS ───────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Local editor / tooling settings ───────────────────────
.claude/

# ── Local-only demo/seed data (kept out of the repo) ──────
scripts/demo-seed.sql

# ── Wazuh ruleset (GPLv2, Copyright Wazuh Inc.) + rules derived from it ────
# Kept out of this (public) repo to avoid GPL/license conflicts. The wazuh2sigma
# converter under tools/ is original code and IS tracked; its INPUT and OUTPUT are not.
Wazuh_Rules/
Wazuh_Decoders/
rules/wazuh-imported/
decoders/wazuh-imported/

# ── Database backups (scripts/backup.sh) ──────────────────
/backups/
