# Shrink the Docker build context — Go code + the assets the binary needs.
# NOTE: migrations/ MUST be present (embedded via go:embed in the migrations package);
# rules/ is used by the worker image. Do not exclude either of them.
.git/
.github/
.claude/
web/
docs/
deploy/
*.md
.env
.env.*
!.env.example
.gitignore
.gitattributes
