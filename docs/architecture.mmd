  %% ══════════════ MANAGER ══════════════
  subgraph MGR["🏰 MANAGER — one docker compose host"]
    direction TB
    CG["certgen (init container)<br/>private CA + mTLS certificates"]
    GW["Ingest Gateway :9443 (mTLS only)<br/>enrollment: token → client cert (CN+serial pinning)<br/>config push · heartbeat · revocation<br/>custom decoders (regex→fields, live-reload)<br/>normalization → DCS event schema"]
    BUS["NATS JetStream<br/>durable event bus (logs.normalized)"]

    subgraph WK["Worker — detection & response pipeline"]
      DET["Detection:<br/>Sigma single-event + aggregation → SQL<br/>DB-managed rules (UI-editable)<br/>auto MITRE ATT&CK labeling<br/>remediation playbooks per label"]
      ENR["CTI Enrichment + Composite Scoring<br/>abuse+otx+severity+fired+anomaly → 0-100<br/>GeoIP · escalation · scenario ban"]
      SUS["Suspicious-IP watchlist<br/>low-and-slow recon<br/>(fan-out · failure-ratio · spread)"]
      HREP["File-hash reputation<br/>VirusTotal · MalwareBazaar · CIRCL"]
      RSP["Response Engine (SOAR)<br/>entity_type decision table<br/>progressive ban 10m→30m→1h→24h→perm<br/>whitelist · approval/auto · containment<br/>trusted-session gate"]
      NTF["Notifications<br/>severity threshold · dedup/throttle · reports"]
      LLMW["LLM Worker<br/>alert triage (opt-in) + AI report summaries"]
      SELF["Self-Monitoring<br/>agent health · disk-watermark janitor<br/>/healthz + /readyz"]
      ARCW["Archive writer<br/>raw daily zstd per source/dataset"]
      CHW["ClickHouse sink writer<br/>batched INSERT … JSONEachRow"]
    end

    DB[("PostgreSQL 16 + TimescaleDB<br/>events hypertable (chunks · compression · retention)<br/>alerts · rules · decoders · bans · tickets · scores<br/>users/RBAC/audit (append-only) · subscriptions<br/>integrations: secrets AES-256-GCM at rest")]
    API["API Server :9080<br/>Argon2id · TOTP 2FA · granular RBAC · lockout<br/>auto-migrations · reports (JSON/MD/PDF)<br/>SUBSCRIPTION API · ML bridge · blocklist feed<br/>webhook export · one-line installer · update check"]
    WEB["Web UI :9173 (React+Vite via nginx)<br/>Dashboard · Events · Response · Rules · Decoders<br/>Playbooks · Agents · Integrations · Tickets · Report · Users · Settings"]
  end

