# Konfigurasi agent DeusWatch. Salin ke /etc/deuswatch/agent.env lalu sesuaikan.

# URL manager (gateway) — wajib.
GATEWAY_URL=https://manager.example:8443

# Direktori sertifikat mTLS agent (ca.crt, client.crt, client.key).
CERT_DIR=/etc/deuswatch/certs

# Nama host yang dilaporkan (kosong = hostname OS).
HOST_NAME=

# Opsional: override sumber tunggal (selain itu pakai default per-OS).
# LOG_FILE=/var/log/auth.log
# DATASET=sshd

# 1 = kirim juga baris yang sudah ada saat start (default 0 = hanya baris baru).
FROM_START=0

# Direktori buffer store-and-forward (saat manager offline).
BUFFER_DIR=/var/lib/deuswatch/buffer
