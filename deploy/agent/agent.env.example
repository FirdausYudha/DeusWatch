# DeusWatch agent configuration. Copy to /etc/deuswatch/agent.env then adjust.

# Manager (gateway) URL — required.
GATEWAY_URL=https://manager.example:8443

# Agent mTLS certificate directory (ca.crt, client.crt, client.key).
CERT_DIR=/etc/deuswatch/certs

# Reported host name (empty = OS hostname).
HOST_NAME=

# Optional: override with a single source (otherwise use the per-OS defaults).
# LOG_FILE=/var/log/auth.log
# DATASET=sshd

# 1 = also send lines that already exist at start (default 0 = only new lines).
FROM_START=0

# Store-and-forward buffer directory (while the manager is offline).
BUFFER_DIR=/var/lib/deuswatch/buffer
