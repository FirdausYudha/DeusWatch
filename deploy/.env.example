# Copy to deploy/.env then adjust. The .env file (without .example) is gitignored.
#
#   cp deploy/.env.example deploy/.env

# PostgreSQL password. MUST be changed for anything other than local dev.
# Takes effect on a FRESH db volume (Postgres sets it on first init).
POSTGRES_PASSWORD=deuswatch_dev

# Initial admin account, seeded only when the users table is empty (first start).
# To change the password later without wiping the DB, use Settings → Change password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Self-registration on the login page. 0 = off (default; admins create users in the UI),
# 1 = allow new viewer-role accounts to sign up from the login screen.
REGISTRATION_ENABLED=0

# Master key for encrypting integration secrets (API keys, device passwords) at rest.
# Base64 of 32 random bytes - generate with:  openssl rand -base64 32
# Without it a fixed DEV key is used (NOT safe for production). Changing it later makes
# previously-stored integration secrets undecryptable - re-enter them after rotating.
SECRETS_KEY=

# ── Host-published ports ───────────────────────────────────────────────────
# The containers always listen on 8080 (api), 8443 (gateway), 80 (web) internally;
# these only change the HOST port mapping, to avoid collisions with other apps.
# Defaults avoid the common 8080/5173. The Add-agent wizard reads API/GATEWAY ports
# automatically so the generated install command stays correct.
DEUSWATCH_WEB_PORT=9173
DEUSWATCH_API_PORT=9080
DEUSWATCH_GATEWAY_PORT=9443
DEUSWATCH_DB_PORT=5432

# Bind address for the host-published Postgres port. Default 127.0.0.1 = local tools
# only (the stack itself uses the internal Docker network). Set 0.0.0.0 to accept LAN
# connections (e.g. a streaming-replication standby - docs/storage.md) + firewall it.
DEUSWATCH_DB_BIND=127.0.0.1

# ── Login hardening (see docs/production.md) ───────────────────────────────
# Lock an IP/username out of /api/login after N failures (0 disables) for LOGIN_LOCKOUT.
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT=15m
# Minimum length for NEW passwords (floor 8; existing accounts are not re-checked).
PASSWORD_MIN_LEN=8
# Reverse proxies whose X-Forwarded-For is trusted for the real client IP. Default
# covers the bundled web/nginx container (Docker network). Add the IP of any extra
# TLS proxy that runs on ANOTHER machine (comma-separated CIDRs or IPs).
TRUSTED_PROXIES=172.16.0.0/12

# Container memory caps (docker compose deploy.resources.limits).
DEUSWATCH_DB_MEM=1g
DEUSWATCH_WORKER_MEM=1g

# ── CTI enrichment (threat intel: country + abuse score) ───────────────────
# Without a key DeusWatch uses a MOCK provider (shows "-" for unknown IPs, not real data).
# Add a real key for genuine reputation/country. Integrations UI takes precedence over these.
ABUSEIPDB_API_KEY=
OTX_API_KEY=
# Free GeoIP via ip-api.com (country/city) as a fallback when AbuseIPDB has no country. 1=on.
GEOIP_ENABLED=0
# The CTI dedup window (how often an IP may be re-queried) is set in the UI:
# Settings -> Threat-intel (CTI) caching. Default 24h.

# ── Log storage (see docs/storage.md) ──────────────────────────────────────
# Point the api + worker at an EXTERNAL/remote PostgreSQL (e.g. Server B) instead of the
# bundled db service. Migrations auto-apply on api start. sslmode=require over a network.
# DATABASE_URL=postgres://deuswatch:STRONG_PASSWORD@server-b.example:5432/deuswatch?sslmode=require
# STORE_DSN=postgres://deuswatch:STRONG_PASSWORD@server-b.example:5432/deuswatch?sslmode=require
#
# Soft storage budget: enables the dashboard usage bar + a near-full notification.
# 0/unset = no bar/alert (retention still ages out old data). Alert sent once/day.
STORAGE_BUDGET_GB=0
STORAGE_ALERT_PERCENT=85
# Disk-watermark janitor (safety net): when the DB crosses this percent of the budget,
# the worker drops the OLDEST event chunks early and raises a HIGH selfhealth alert.
# Deliberately 90, not ~98 - Postgres running out of disk risks corruption. 0 = off.
STORAGE_JANITOR_PERCENT=90

# ── Suspicious-IP watchlist (low-and-slow recon) ─────────────────────────────
# The worker flags EXTERNAL IPs whose behaviour over a long window looks like scanning (many
# distinct targets, failures, spread over time) even without a CTI/WAF hit. On by default.
# SUSPICIOUS_WINDOW=24h        # how far back behaviour is measured
# SUSPICIOUS_INTERVAL=5m       # how often the watchlist is recomputed
# See docs/suspicious-ips.md.

# ── Native syslog input (agentless devices) ─────────────────────────────────
# Listen for syslog (UDP + TCP, RFC3164/RFC5424) so routers/switches/firewalls/appliances can
# ship logs without a DeusWatch agent. Empty = off. Set a host:port and PUBLISH it on the worker
# in docker-compose (e.g. "5514:5514/udp" and "5514:5514/tcp"). The program tag (sshd, kernel…)
# becomes the dataset, so the right decoder runs. SYSLOG_DATASET labels tag-less messages.
# Port 514 needs root/CAP_NET_BIND_SERVICE; 5514 avoids that. See docs/syslog.md.
# SYSLOG_LISTEN=:5514
# SYSLOG_DATASET=syslog

# ── Rule-pack feed (Rules -> Rule packs) ─────────────────────────────────────
# Curated packs BUNDLED in DeusWatch always install with no network. In addition, the manager
# can fetch packs from an online feed so new/updated packs arrive without upgrading the app.
# Default = the DeusWatch project's own packs feed (you control it). This is the only outbound
# request the manager makes for rules; only Sigma YAML is fetched and every file must parse
# before it is stored. Set to "off" (or empty) to disable the feed entirely - no egress.
# PACKS_FEED_URL=https://raw.githubusercontent.com/FirdausYudha/DeusWatch/main/packs

# ── FIM real-time watching ───────────────────────────────────────────────────
# FIM detects changes in real time via fsnotify (inotify / ReadDirectoryChangesW / kqueue) with
# interval polling kept as a safety net. Set in the AGENT's environment. FIM_REALTIME=0 disables
# the watcher (poll-only) - useful if the endpoint is short on inotify watches for a huge tree.
# AGENT_WHODATA and the poll interval (per FIM source) still apply.
# FIM_REALTIME=1

# ── FIM who-data (Linux) ─────────────────────────────────────────────────────
# Attribute each FIM file change to the process/user that made it, via the Linux audit
# subsystem. Opt-in and set in the AGENT's environment (needs root + auditd on the endpoint;
# it installs an audit watch rule on each FIM directory). 0/unset = FIM without the "who".
# AGENT_WHODATA=1
# AGENT_AUDIT_LOG=/var/log/audit/audit.log   # override if your audit log lives elsewhere
# See docs/whodata.md.

# ── Agent self-monitoring ───────────────────────────────────────────────────
# An agent whose heartbeat (every 30s) is silent for AGENT_DISCONNECT_AFTER is marked
# disconnected and raises a HIGH selfhealth alert (a dead agent can mean an attacker
# killed it). After AGENT_STALE_AFTER it becomes stale (no further alert).
AGENT_DISCONNECT_AFTER=2m
AGENT_STALE_AFTER=24h

# IP/hostname that AGENTS use to reach this manager. Added to the mTLS server-cert SAN
# so agents on other machines pass TLS verification. Set this to the host's LAN IP
# (e.g. 192.168.81.134) BEFORE the first start. Empty = localhost only.
MANAGER_IP=

# ── Notification channels (alerts + scheduled report delivery) ─────────────
# The alert severity threshold and the report-delivery schedule are configured in
# the UI (Settings → Alert notifications, Report → Scheduled delivery). The channel
# CREDENTIALS live here because they are secrets. Empty = that channel is disabled.

# Telegram: create a bot with @BotFather to get the token, then get your chat id
# (DM the bot and read https://api.telegram.org/bot<TOKEN>/getUpdates, or use @userinfobot;
# for a group, add the bot to the group and use the negative group chat id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP). SMTP_TO is comma-separated. Defaults: SMTP_PORT=587.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# Fallback alert threshold used until you set one in the UI (info|low|medium|high|critical).
NOTIFY_MIN_SEVERITY=high
# Per rule+IP dedup window for alerts (Go duration, e.g. 10m, 1h).
NOTIFY_THROTTLE=10m

# MikroTik push responder via env (Integrations UI is preferred - it supports multiple routers).
# MIKROTIK_INSECURE=1 skips TLS verification for a self-signed RouterOS cert (safe over a
# WireGuard/IPsec tunnel). See docs/mikrotik.md.
# MIKROTIK_URL=https://10.10.0.1
# MIKROTIK_USER=deuswatch
# MIKROTIK_PASS=
# MIKROTIK_LIST=deuswatch_ban
# MIKROTIK_INSECURE=0

# ── Response / containment ─────────────────────────────────────────────────
# Master switch for REAL enforcement. 0 (default) = dry-run: DeusWatch LOGS the block it
# WOULD apply but pushes NOTHING to MikroTik/nftables/etc (safe for testing). 1 = execute
# for real. A configured MikroTik with RESPONSE_LIVE unset is the #1 "bans never arrive"
# gotcha - the worker log warns about it. After changing, recreate the worker so .env is
# re-read:  docker compose -f deploy/docker-compose.yml up -d --force-recreate worker
RESPONSE_LIVE=0
# Execute bans without manual approval (1) or hold them for one-click approval in the UI (0).
RESPONSE_AUTO_APPROVE=0
# How often active blocks are reconciled onto every sync-capable router (MikroTik). Default 10s.
RESPONSE_SYNC_INTERVAL=10s

# Trusted-session gate: a plain file-change alert (e.g. index.php edited) is suppressed as an
# official change when the same host had a successful login from a WHITELISTED IP within this
# window (set the IP whitelist in Response). Webshell/containment rules are never gated, and
# with an empty whitelist nothing is suppressed. Go duration, e.g. 15m, 1h.
FILE_CHANGE_TRUSTED_WINDOW=15m
# Auto network-containment: 1 = isolate a compromised host immediately when a containment rule
# fires at/above its threshold; 0 (default) = create a recommendation for one-click approval.
CONTAINMENT_AUTO=0
# Blocklist feed: a secret token that unlocks GET /api/blocklist?token=... - a plaintext/JSON
# list of the currently-banned IPs that external firewalls can fetch (Palo Alto EDL, OPNsense
# URL table, pfSense pfBlockerNG, MikroTik). Empty = feed disabled. Generate: openssl rand -hex 24
# See docs/blocklist-feed.md.
# Raw-log ingest webhook (e.g. a Wazuh manager pushing alerts). Empty = disabled (404).
# POST /api/ingest/webhook?token=...&agent=<name>&dataset=wazuh  -  see docs/wazuh-webhook.md
# Prefer the UI: Integrations -> "Log ingest webhook" (enable/regenerate/disable, no restart).
# This env value is only SEEDED into the DB on first start if no token exists yet; after that
# the UI-managed token wins. Generate: openssl rand -hex 24
INGEST_WEBHOOK_TOKEN=

BLOCKLIST_FEED_TOKEN=
